[flake8]
max-line-length = 99
max-complexity = 12
extend-ignore =
    # Whitespace before ':' (conflicts with Black)
    E203,
    # Line break before binary operator (conflicts with Black)
    W503,
    # Line length too long (handled by other formatters)
    E501
per-file-ignores =
    # Allow unused imports in __init__.py
    __init__.py:F401
    # Exclude tests from docstring requirements
    tests/*:D100,D101,D102,D103,D104
exclude =
    .git,
    __pycache__,
    build,
    dist,
    docs,
    venv,
    .venv,
    .DS_Store,
    .idea,
    .vscode,
    .gitignore,
    .gitattributes,
    .travis.yml,
    .pre-commit-config.yaml,
    .flake8-cache,
    .mypy_cache,
    .pytest_cache,
    .coverage
docstring-convention = numpy
